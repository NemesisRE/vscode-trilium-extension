{
  "name": "trilium-notes",
  "displayName": "Trilium Notes",
  "description": "Browse and edit Trilium Notes directly in VS Code via ETAPI",
  "version": "1.0.0",
  "publisher": "NemesisRE",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/NemesisRE/vscode-trilium-extension"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "trilium.textEditor",
        "displayName": "Trilium Text Editor",
        "selector": [
          {
            "filenamePattern": "*.trilium-text"
          }
        ],
        "priority": "default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trilium",
          "title": "Trilium Notes",
          "icon": "media/trilium.svg"
        }
      ]
    },
    "views": {
      "trilium": [
        {
          "id": "triliumNoteTree",
          "name": "Notes",
          "icon": "media/trilium.svg",
          "contextualTitle": "Trilium Notes"
        },
        {
          "id": "triliumNoteAttributes",
          "name": "Attributes",
          "type": "webview",
          "icon": "media/trilium.svg",
          "contextualTitle": "Trilium Notes"
        }
      ]
    },
    "commands": [
      {
        "command": "trilium.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Trilium"
      },
      {
        "command": "trilium.connect",
        "title": "Connect to Trilium Server",
        "icon": "$(debug-disconnect)",
        "category": "Trilium"
      },
      {
        "command": "trilium.reconnect",
        "title": "Reconnect to Trilium Server",
        "icon": "$(database)",
        "category": "Trilium"
      },
      {
        "command": "trilium.openNote",
        "title": "Open Note",
        "icon": "$(edit)",
        "category": "Trilium"
      },
      {
        "command": "trilium.openNoteAsHtml",
        "title": "Open as HTML",
        "icon": "$(file-code)",
        "category": "Trilium"
      },
      {
        "command": "trilium.openNoteAsMarkdown",
        "title": "Open as Markdown",
        "icon": "$(markdown)",
        "category": "Trilium"
      },
      {
        "command": "trilium.createNote",
        "title": "New Note",
        "icon": "$(add)",
        "category": "Trilium"
      },
      {
        "command": "trilium.openInBrowser",
        "title": "Open in Browser",
        "icon": "$(browser)",
        "category": "Trilium"
      },
      {
        "command": "trilium.openInBrowserExternal",
        "title": "Open in External Browser",
        "icon": "$(link-external)",
        "category": "Trilium"
      },
      {
        "command": "trilium.downloadFile",
        "title": "Download File",
        "icon": "$(cloud-download)",
        "category": "Trilium"
      },
      {
        "command": "trilium.renameNote",
        "title": "Rename Note",
        "category": "Trilium"
      },
      {
        "command": "trilium.createNoteText",
        "title": "New Text Note",
        "icon": "$(edit)",
        "category": "Trilium"
      },
      {
        "command": "trilium.createNoteCode",
        "title": "New Code Note",
        "icon": "$(code)",
        "category": "Trilium"
      },
      {
        "command": "trilium.createNoteMermaid",
        "title": "New Mermaid Diagram",
        "icon": "$(type-hierarchy)",
        "category": "Trilium"
      },
      {
        "command": "trilium.createNoteCanvas",
        "title": "New Canvas (Excalidraw)",
        "icon": "$(symbol-misc)",
        "category": "Trilium"
      },
      {
        "command": "trilium.createNoteMindMap",
        "title": "New Mind Map Note",
        "icon": "$(type-hierarchy-sub)",
        "category": "Trilium"
      },
      {
        "command": "trilium.createNoteWithContent",
        "title": "Create Note With Content (programmatic)",
        "category": "Trilium"
      },
      {
        "command": "trilium.importNotes",
        "title": "Import Notes from JSON",
        "icon": "$(cloud-upload)",
        "category": "Trilium"
      },
      {
        "command": "trilium.openTodayNote",
        "title": "Open Today's Journal Note",
        "icon": "$(calendar)",
        "category": "Trilium"
      },
      {
        "command": "trilium.deleteNote",
        "title": "Delete Note",
        "icon": "$(trash)",
        "category": "Trilium"
      },
      {
        "command": "trilium.copyNoteId",
        "title": "Copy Note ID",
        "category": "Trilium"
      },
      {
        "command": "trilium.copyNoteUrl",
        "title": "Copy Trilium URL",
        "category": "Trilium"
      },
      {
        "command": "trilium.openCalendarNote",
        "title": "Open Calendar Note...",
        "icon": "$(calendar-clock)",
        "category": "Trilium"
      },
      {
        "command": "trilium.openInboxNote",
        "title": "Open Inbox Note",
        "category": "Trilium"
      },
      {
        "command": "trilium.openWeekNote",
        "title": "Open This Week's Note",
        "category": "Trilium"
      },
      {
        "command": "trilium.openMonthNote",
        "title": "Open This Month's Note",
        "category": "Trilium"
      },
      {
        "command": "trilium.openYearNote",
        "title": "Open This Year's Note",
        "category": "Trilium"
      },
      {
        "command": "trilium.searchNotes",
        "title": "Search Notes...",
        "icon": "$(search)",
        "category": "Trilium"
      },
      {
        "command": "trilium.filterTree",
        "title": "Filter Tree...",
        "icon": "$(filter)",
        "category": "Trilium"
      },
      {
        "command": "trilium.clearTreeFilter",
        "title": "Clear Tree Filter",
        "icon": "$(filter-filled)",
        "category": "Trilium"
      },
      {
        "command": "trilium.showRevisions",
        "title": "Show Note Revisions...",
        "icon": "$(history)",
        "category": "Trilium"
      },
      {
        "command": "trilium.cloneNote",
        "title": "Clone Note...",
        "icon": "$(copy)",
        "category": "Trilium"
      },
      {
        "command": "trilium.moveNote",
        "title": "Move Note...",
        "icon": "$(arrow-right)",
        "category": "Trilium"
      },
      {
        "command": "trilium.exportSubtree",
        "title": "Export Subtree...",
        "icon": "$(package)",
        "category": "Trilium"
      }
    ],
    "submenus": [
      {
        "id": "trilium.newNoteSubmenu",
        "label": "New Note...",
        "icon": "$(add)"
      },
      {
        "id": "trilium.openAsSubmenu",
        "label": "Open as...",
        "icon": "$(file-code)"
      }
    ],
    "menus": {
      "view/title/context": [
        {
          "command": "trilium.createNote",
          "when": "view == triliumNoteTree",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "trilium.searchNotes",
          "when": "view == triliumNoteTree",
          "group": "navigation@0"
        },
        {
          "command": "trilium.clearTreeFilter",
          "when": "view == triliumNoteTree && trilium.treeFiltered",
          "group": "navigation@1"
        },
        {
          "command": "trilium.filterTree",
          "when": "view == triliumNoteTree && !trilium.treeFiltered",
          "group": "navigation@1"
        },
        {
          "command": "trilium.createNote",
          "when": "view == triliumNoteTree",
          "group": "navigation"
        },
        {
          "command": "trilium.importNotes",
          "when": "view == triliumNoteTree",
          "group": "navigation"
        },
        {
          "command": "trilium.openTodayNote",
          "when": "view == triliumNoteTree",
          "group": "navigation"
        },
        {
          "command": "trilium.refresh",
          "when": "view == triliumNoteTree",
          "group": "navigation"
        }
      ],
      "trilium.newNoteSubmenu": [
        {
          "command": "trilium.createNoteText",
          "group": "types@1"
        },
        {
          "command": "trilium.createNoteCode",
          "group": "types@2"
        },
        {
          "command": "trilium.createNoteMermaid",
          "group": "types@3"
        },
        {
          "command": "trilium.createNoteCanvas",
          "group": "types@4"
        },
        {
          "command": "trilium.createNoteMindMap",
          "group": "types@5"
        }
      ],
      "trilium.openAsSubmenu": [
        {
          "command": "trilium.openNoteAsMarkdown",
          "group": "formats@1"
        },
        {
          "command": "trilium.openNoteAsHtml",
          "group": "formats@2"
        }
      ],
      "view/item/context": [
        {
          "command": "trilium.openNote",
          "when": "viewItem == noteText",
          "group": "inline"
        },
        {
          "command": "trilium.openNote",
          "when": "viewItem == noteCode",
          "group": "inline"
        },
        {
          "command": "trilium.downloadFile",
          "when": "viewItem == noteFile",
          "group": "inline"
        },
        {
          "command": "trilium.openInBrowser",
          "when": "viewItem == noteExternal",
          "group": "inline"
        },
        {
          "command": "trilium.openNote",
          "when": "viewItem == noteText",
          "group": "navigation@1"
        },
        {
          "submenu": "trilium.openAsSubmenu",
          "when": "viewItem == noteText",
          "group": "navigation@2"
        },
        {
          "command": "trilium.openNote",
          "when": "viewItem == noteCode",
          "group": "navigation@1"
        },
        {
          "command": "trilium.downloadFile",
          "when": "viewItem == noteFile",
          "group": "navigation@1"
        },
        {
          "command": "trilium.openInBrowser",
          "when": "viewItem == noteText",
          "group": "navigation@3"
        },
        {
          "command": "trilium.openInBrowser",
          "when": "viewItem == noteCode",
          "group": "navigation@2"
        },
        {
          "command": "trilium.openInBrowser",
          "when": "viewItem == noteFile",
          "group": "navigation@2"
        },
        {
          "command": "trilium.openInBrowser",
          "when": "viewItem == noteExternal",
          "group": "navigation@1"
        },
        {
          "command": "trilium.openInBrowserExternal",
          "when": "viewItem == noteText",
          "group": "navigation@4"
        },
        {
          "command": "trilium.openInBrowserExternal",
          "when": "viewItem == noteCode",
          "group": "navigation@3"
        },
        {
          "command": "trilium.openInBrowserExternal",
          "when": "viewItem == noteFile",
          "group": "navigation@3"
        },
        {
          "command": "trilium.openInBrowserExternal",
          "when": "viewItem == noteExternal",
          "group": "navigation@2"
        },
        {
          "submenu": "trilium.newNoteSubmenu",
          "when": "viewItem =~ /^note(Text|Code|File|External)$/",
          "group": "1_modification@1"
        },
        {
          "command": "trilium.renameNote",
          "when": "viewItem == noteText",
          "group": "1_modification@2"
        },
        {
          "command": "trilium.renameNote",
          "when": "viewItem == noteCode",
          "group": "1_modification@2"
        },
        {
          "command": "trilium.renameNote",
          "when": "viewItem == noteFile",
          "group": "1_modification@2"
        },
        {
          "command": "trilium.renameNote",
          "when": "viewItem == noteExternal",
          "group": "1_modification@2"
        },
        {
          "command": "trilium.deleteNote",
          "when": "viewItem =~ /^note(Text|Code|File|External)$/",
          "group": "2_delete@1"
        },
        {
          "command": "trilium.copyNoteId",
          "when": "viewItem =~ /^note(Text|Code|File|External)$/",
          "group": "9_copy@1"
        },
        {
          "command": "trilium.copyNoteUrl",
          "when": "viewItem =~ /^note(Text|Code|File|External)$/",
          "group": "9_copy@2"
        },
        {
          "command": "trilium.showRevisions",
          "when": "viewItem =~ /^note(Text|Code|File|External)$/",
          "group": "3_history@1"
        },
        {
          "command": "trilium.cloneNote",
          "when": "viewItem =~ /^note(Text|Code|File|External)$/",
          "group": "3_history@2"
        },
        {
          "command": "trilium.moveNote",
          "when": "viewItem =~ /^note(Text|Code|File|External)$/",
          "group": "3_history@3"
        },
        {
          "command": "trilium.exportSubtree",
          "when": "viewItem =~ /^note(Text|Code|File|External)$/",
          "group": "3_history@4"
        }
      ]
    },
    "languageModelTools": [
      {
        "name": "trilium_createNote",
        "displayName": "Create Trilium Note",
        "modelDescription": "Creates a single note in Trilium Notes. Supports types: text (rich HTML), code (source code with language), mermaid (diagram), canvas (Excalidraw drawing). Returns the new noteId.",
        "tags": [
          "trilium",
          "notes",
          "create"
        ],
        "inputSchema": {
          "type": "object",
          "required": [
            "title",
            "type",
            "content"
          ],
          "properties": {
            "parentNoteId": {
              "type": "string",
              "description": "ID of the parent note. Use 'root' to create at the top level. Omit to default to 'root'."
            },
            "title": {
              "type": "string",
              "description": "Title of the new note."
            },
            "type": {
              "type": "string",
              "enum": [
                "text",
                "code",
                "mermaid",
                "canvas"
              ],
              "description": "Note type. 'text'=rich HTML, 'code'=source code, 'mermaid'=Mermaid diagram syntax, 'canvas'=Excalidraw JSON."
            },
            "content": {
              "type": "string",
              "description": "Note body. For 'text': CKEditor HTML (e.g. '<p>Hello</p>'). For 'mermaid': raw Mermaid syntax (no code fences). For 'canvas': Excalidraw JSON string. For 'code': raw source code."
            },
            "mime": {
              "type": "string",
              "description": "MIME type — required for 'code' notes (e.g. 'text/javascript', 'text/x-python'). Ignored for other types."
            }
          }
        }
      },
      {
        "name": "trilium_importNotes",
        "displayName": "Import Notes Tree to Trilium",
        "modelDescription": "Recursively creates an entire hierarchy of notes in Trilium Notes from a JSON spec. Use this when the user asks to create documentation, a set of notes, or any multi-level note structure. Returns the total number of notes created.",
        "tags": [
          "trilium",
          "notes",
          "import",
          "documentation"
        ],
        "inputSchema": {
          "type": "object",
          "required": [
            "notes"
          ],
          "properties": {
            "parentNoteId": {
              "type": "string",
              "description": "ID of the parent note to create everything under. Use 'root' for the top level. Omit to default to 'root'."
            },
            "notes": {
              "type": "array",
              "description": "Array of NoteImportSpec objects to create recursively.",
              "items": {
                "$ref": "#/$defs/NoteImportSpec"
              }
            }
          },
          "$defs": {
            "NoteImportSpec": {
              "type": "object",
              "required": [
                "title"
              ],
              "properties": {
                "title": {
                  "type": "string",
                  "description": "Note title."
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "text",
                    "code",
                    "mermaid",
                    "canvas"
                  ],
                  "description": "Note type. Defaults to 'text'."
                },
                "mime": {
                  "type": "string",
                  "description": "MIME type for code notes (e.g. 'text/javascript')."
                },
                "content": {
                  "type": "string",
                  "description": "Note body (HTML for text, Mermaid syntax for mermaid, Excalidraw JSON for canvas, raw source for code)."
                },
                "children": {
                  "type": "array",
                  "description": "Child notes to create recursively under this note.",
                  "items": {
                    "$ref": "#/$defs/NoteImportSpec"
                  }
                }
              }
            }
          }
        }
      },
      {
        "name": "trilium_searchNotes",
        "displayName": "Search Trilium Notes",
        "modelDescription": "Searches notes in Trilium by a text query. Returns a list of matching notes with their noteId, title, type, and parent note title. Use this to find relevant notes before reading or linking them.",
        "tags": [
          "trilium",
          "notes",
          "search"
        ],
        "inputSchema": {
          "type": "object",
          "required": [
            "query"
          ],
          "properties": {
            "query": {
              "type": "string",
              "description": "Full-text search query."
            },
            "ancestorNoteId": {
              "type": "string",
              "description": "Restrict the search to descendants of this note ID. Omit to search all notes."
            },
            "limit": {
              "type": "number",
              "description": "Maximum number of results to return (default: 20, max: 100)."
            }
          }
        }
      },
      {
        "name": "trilium_readNote",
        "displayName": "Read Trilium Note Content",
        "modelDescription": "Reads the content of a specific Trilium note by its noteId. Returns the note title, type, and content as plain text (HTML stripped). Use this to inspect, summarise, or answer questions about a specific note.",
        "tags": [
          "trilium",
          "notes",
          "read"
        ],
        "inputSchema": {
          "type": "object",
          "required": [
            "noteId"
          ],
          "properties": {
            "noteId": {
              "type": "string",
              "description": "The ID of the note to read."
            }
          }
        }
      },
      {
        "name": "trilium_listChildren",
        "displayName": "List Trilium Note Children",
        "modelDescription": "Lists the direct child notes of a given Trilium note. Returns an array of noteId, title, and type. Use this to navigate the note tree or find child notes before reading them.",
        "tags": [
          "trilium",
          "notes",
          "navigate"
        ],
        "inputSchema": {
          "type": "object",
          "required": [
            "noteId"
          ],
          "properties": {
            "noteId": {
              "type": "string",
              "description": "The ID of the parent note whose children should be listed. Use 'root' for the top level."
            }
          }
        }
      }
    ],
    "keybindings": [
      {
        "command": "trilium.renameNote",
        "key": "F2",
        "when": "focusedView == triliumNoteTree || view == triliumNoteTree"
      }
    ],
    "configuration": {
      "title": "Trilium Notes",
      "properties": {
        "trilium.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the Trilium Notes server (e.g. http://localhost:8080)"
        },
        "trilium.rootNoteId": {
          "type": "string",
          "default": "root",
          "description": "Note ID to use as the root of the Trilium tree view. Defaults to 'root'. Change this to scope the tree to a specific subtree (workspace / hoisting equivalent)."
        },
        "trilium.editor.fontSize": {
          "type": "number",
          "default": 14,
          "minimum": 8,
          "maximum": 32,
          "description": "Font size in pixels for the CKEditor content area."
        },
        "trilium.editor.spellcheck": {
          "type": "boolean",
          "default": false,
          "description": "Enable the browser's built-in spellcheck in the CKEditor content area."
        }
      }
    }
  },
  "scripts": {
    "prebuild": "node scripts/download-trilium-plugins.mjs",
    "vscode:prepublish": "npm run prebuild && node esbuild.mjs --production",
    "build": "node esbuild.mjs",
    "build:prod": "npm run prebuild && node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc --noEmit",
    "compile:tests": "tsc -p tsconfig.test.json",
    "test:unit": "npm run compile:tests && mocha",
    "test:integration": "npm run build && npm run compile:tests && vscode-test",
    "test": "npm run test:unit",
    "test:all": "npm run test:unit && npm run test:integration",
    "lint": "tsc --noEmit",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "ckeditor5": "^48.0.0",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.5",
    "tar": "^7.4.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "marked": "^18.0.3",
    "mathlive": "^0.109.1",
    "mermaid": "^11.14.0",
    "turndown": "^7.2.4"
  }
}
